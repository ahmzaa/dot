# NOTE: we use our own zsh framework (plugins in ~/.zsh/plugins), NOT
# oh-my-zsh. We deliberately do NOT source setup/shell/source (it loads omz
# and conflicts with our plugins -> double-wrapped ZLE widgets / FUNCNEST).
# The flag ~/.cw-fleet-tools/.skip_shell also stops setup/source from
# auto-loading it. Fleet-tools completions are re-added below.
# (If `cwft zsh` ever reinstalls oh-my-zsh, re-create the skip flag:
#   mkdir -p ~/.cw-fleet-tools && touch ~/.cw-fleet-tools/.skip_shell)
source $HOME/coreweave/cw-fleet-tools/setup/source

export PATH=$PATH:$HOME/coreweave/cw-fleet-tools/team/jfields

# CoreWeave Netskope SSL fix — combined CA bundle for Node.js, Go and Python tools (re-run setup.sh to refresh)
export NODE_EXTRA_CA_CERTS="/Users/hahmed/.certs/ca-bundle.pem"
export SSL_CERT_FILE="/Users/hahmed/.certs/ca-bundle.pem"
export REQUESTS_CA_BUNDLE="/Users/hahmed/.certs/ca-bundle.pem"

has(){
    command -v $1 &> /dev/null
}
has cwctl && . <(cwctl completion zsh)
has kubectl && . <(kubectl completion zsh) && compdef _kubectl kubectl && compdef _kubectl k && compdef _kubectl kubecolor
has gh && . <(gh completion -s zsh) && compdef _gh gh
has op && . <(op completion zsh) && compdef _op op

# SSH: agent is sourced globally from .zshrc (OS-aware).
# One-time bootstrap on this machine to store the key passphrase in the
# macOS Keychain so it auto-loads on every login:
#   ssh-add --apple-use-keychain ~/.ssh/id_ed25519

