#!/usr/bin/env bash
#####################################################################
# Dotfiles installer
#
# Cross-platform (macOS + Linux). Detects the package manager, lets you
# choose which stow packages to install (individually or by group),
# installs a curated set of core dependencies plus any per-package
# extras, checks neovim against the latest stable, stows your selection,
# and (optionally) sets zsh as your login shell.
#
# Safe to re-run; stow is applied with --restow.
#####################################################################
set -euo pipefail

#--------------------------------------------------------------------
# Output helpers
#--------------------------------------------------------------------
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[0;33m'; BLUE='\033[0;34m'; NC='\033[0m'
info()  { printf "${GREEN}==>${NC} %s\n" "$*"; }
warn()  { printf "${YELLOW}==> warning:${NC} %s\n" "$*"; }
error() { printf "${RED}==> error:${NC} %s\n" "$*" >&2; }
step()  { printf "\n${BLUE}==> %s${NC}\n" "$*"; }

confirm() {
    # confirm "Question?" -> returns 0 for yes, 1 for no (default No)
    local prompt="${1:-Continue?}" reply
    printf "${GREEN}%s${NC} [y/N] " "$prompt"
    read -r reply
    [[ "$reply" =~ ^[Yy]$ ]]
}

# Track dependencies we couldn't install so we can report them at the end.
MANUAL_DEPS=()

#--------------------------------------------------------------------
# Repo root (auto-detected from this script's location)
#--------------------------------------------------------------------
REPO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"

# Every top-level dir except non-stow ones is a package.
NON_PACKAGES=(docs)

# Print the repo banner (ASCII art) if present.
print_banner() {
    local banner="$REPO_DIR/zsh/.config/zsh/banner"
    if [[ -f "$banner" ]]; then
        printf "${GREEN}"
        cat "$banner"
        printf "${NC}\n"
    fi
}

#--------------------------------------------------------------------
# OS / package-manager detection
#--------------------------------------------------------------------
OS=""; PM=""
detect_platform() {
    case "$(uname -s)" in
        Darwin) OS="macos" ;;
        Linux)  OS="linux" ;;
        *) error "Unsupported OS: $(uname -s)"; exit 1 ;;
    esac

    if [[ "$OS" == "macos" ]]; then
        PM="brew"
    elif command -v apt >/dev/null 2>&1; then
        PM="apt"
    elif command -v pacman >/dev/null 2>&1; then
        PM="pacman"
    elif command -v dnf >/dev/null 2>&1; then
        PM="dnf"
    else
        error "No supported package manager found (need brew, apt, pacman or dnf)."
        exit 1
    fi
    info "Detected OS: $OS, package manager: $PM"
}

ensure_homebrew() {
    [[ "$PM" == "brew" ]] || return 0
    if ! command -v brew >/dev/null 2>&1; then
        info "Homebrew not found — installing..."
        /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
        # Make brew available for the rest of this run.
        [[ -x /opt/homebrew/bin/brew ]] && eval "$(/opt/homebrew/bin/brew shellenv)"
        [[ -x /usr/local/bin/brew ]] && eval "$(/usr/local/bin/brew shellenv)"
    fi
    return 0
}

#--------------------------------------------------------------------
# Package-name mapping: generic name -> per-manager name.
# Empty string means "not available on this manager" (skip).
#--------------------------------------------------------------------
map_pkg() {
    local name="$1"
    case "$name" in
        fd)
            case "$PM" in apt) echo "fd-find" ;; *) echo "fd" ;; esac ;;
        ripgrep) echo "ripgrep" ;;
        neovim)  echo "neovim" ;;
        pywal)
            case "$PM" in
                brew) echo "" ;;         # install via pip fallback
                pacman) echo "python-pywal" ;;
                *) echo "" ;;            # pip fallback
            esac ;;
        aerospace)
            case "$PM" in brew) echo "nikitabobko/tap/aerospace" ;; *) echo "" ;; esac ;;
        *) echo "$name" ;;               # default: same name everywhere
    esac
}

pm_install_raw() {
    # Install already-mapped package names for the current manager.
    local pkgs=("$@")
    [[ ${#pkgs[@]} -eq 0 ]] && return 0
    case "$PM" in
        brew)   brew install "${pkgs[@]}" ;;
        apt)    sudo apt install -y "${pkgs[@]}" ;;
        pacman) sudo pacman -S --needed --noconfirm "${pkgs[@]}" ;;
        dnf)    sudo dnf install -y "${pkgs[@]}" ;;
    esac
}

pkg_install() {
    # Install a list of GENERIC names; maps each and installs one-by-one so a
    # single missing package doesn't abort the batch.
    local generic mapped
    for generic in "$@"; do
        mapped="$(map_pkg "$generic")"
        if [[ -z "$mapped" ]]; then
            # No package for this manager — handle special fallbacks.
            case "$generic" in
                pywal)
                    if command -v pip3 >/dev/null 2>&1; then
                        pip3 install --user pywal >/dev/null 2>&1 && continue
                    fi ;;
            esac
            warn "No '$generic' package for $PM — skipping."
            MANUAL_DEPS+=("$generic")
            continue
        fi
        if ! pm_install_raw "$mapped"; then
            warn "Failed to install '$generic' ($mapped) — continuing."
            MANUAL_DEPS+=("$generic")
        fi
    done
}

#--------------------------------------------------------------------
# Curated core dependencies (installed for every setup)
#--------------------------------------------------------------------
CORE_DEPS=(git stow zsh fzf ripgrep fd lsd lolcat tmux)
# neovim handled separately (version check).
# starship and yazi are their own stow packages, so they are installed as
# per-package dependencies (see pkg_deps / install_selected_deps) rather than
# unconditionally here.

# Remove an entry from MANUAL_DEPS (used when a fallback install succeeds).
# Avoid injecting an empty element when the result is empty (bash 3.2 would
# otherwise leave a single "" entry and make the array look non-empty).
unmark_manual() {
    local keep=() d
    for d in "${MANUAL_DEPS[@]:-}"; do
        [[ -z "$d" ]] && continue
        [[ "$d" == "$1" ]] || keep+=("$d")
    done
    MANUAL_DEPS=()
    if [[ ${#keep[@]} -gt 0 ]]; then
        MANUAL_DEPS=("${keep[@]}")
    fi
    return 0
}

# Ensure a C toolchain (cc/linker + make) exists — cargo source builds need it.
ensure_build_tools() {
    if { command -v cc >/dev/null 2>&1 || command -v gcc >/dev/null 2>&1; } \
        && command -v make >/dev/null 2>&1; then
        return 0
    fi
    info "Installing a C compiler toolchain (needed to build from source)..."
    case "$PM" in
        apt)    pkg_install build-essential ;;
        pacman) pkg_install base-devel ;;
        dnf)    sudo dnf groupinstall -y "Development Tools" 2>/dev/null || pkg_install gcc make ;;
        brew)   xcode-select --install 2>/dev/null || true ;;  # usually already present
    esac
    { command -v cc >/dev/null 2>&1 || command -v gcc >/dev/null 2>&1; } \
        && command -v make >/dev/null 2>&1
}

# Ensure cargo is available (for source-built fallbacks like yazi on apt).
ensure_cargo() {
    command -v cargo >/dev/null 2>&1 && return 0
    [[ -f "$HOME/.cargo/env" ]] && . "$HOME/.cargo/env"
    command -v cargo >/dev/null 2>&1 && return 0
    info "Installing Rust toolchain (rustup) for cargo-based installs..."
    curl -sSf https://sh.rustup.rs | sh -s -- -y >/dev/null 2>&1 || return 1
    [[ -f "$HOME/.cargo/env" ]] && . "$HOME/.cargo/env"
    command -v cargo >/dev/null 2>&1
}

install_core_deps() {
    step "Installing core dependencies"
    pkg_install "${CORE_DEPS[@]}"
}

# Fallbacks for tools not always packaged; called after their package's deps
# are attempted, only when that package was selected.
install_starship() {
    pkg_install starship
    if ! command -v starship >/dev/null 2>&1; then
        info "Installing starship via official script..."
        if curl -sS https://starship.rs/install.sh | sh -s -- -y; then
            unmark_manual starship
        fi
    fi
}

# opencode isn't in distro repos — install via its official script.
install_opencode() {
    if command -v opencode >/dev/null 2>&1; then
        info "opencode already installed."
        return 0
    fi
    info "Installing opencode via official script..."
    if curl -fsSL https://opencode.ai/install | bash; then
        unmark_manual opencode
    else
        warn "Could not install opencode automatically."
        MANUAL_DEPS+=("opencode")
    fi
}

# Rust target triple for prebuilt-binary downloads (yazi et al.).
target_triple() {
    local arch os
    case "$(uname -m)" in
        x86_64|amd64) arch="x86_64" ;;
        arm64|aarch64) arch="aarch64" ;;
        *) return 1 ;;
    esac
    case "$(uname -s)" in
        Darwin) os="apple-darwin" ;;
        Linux)  os="unknown-linux-gnu" ;;
        *) return 1 ;;
    esac
    echo "${arch}-${os}"
}

# Install yazi from the official GitHub prebuilt binary (fast, no toolchain).
# Assets look like: yazi-<triple>.zip containing `yazi` and `ya`.
install_yazi_from_github() {
    local triple url tmp
    triple="$(target_triple)" || return 1
    command -v unzip >/dev/null 2>&1 || pkg_install unzip
    command -v unzip >/dev/null 2>&1 || return 1
    url="https://github.com/sxyazi/yazi/releases/latest/download/yazi-${triple}.zip"
    tmp="$(mktemp -d)"
    info "Downloading yazi prebuilt binary ($triple)..."
    if curl -fsSL "$url" -o "$tmp/yazi.zip" && unzip -q "$tmp/yazi.zip" -d "$tmp"; then
        mkdir -p "$HOME/.local/bin"
        # Binaries live in a subdir named after the asset.
        find "$tmp" -type f \( -name yazi -o -name ya \) -exec install -m755 {} "$HOME/.local/bin/" \;
        rm -rf "$tmp"
        command -v yazi >/dev/null 2>&1 || [[ -x "$HOME/.local/bin/yazi" ]]
    else
        rm -rf "$tmp"
        return 1
    fi
}

install_yazi() {
    pkg_install yazi
    command -v yazi >/dev/null 2>&1 && return 0

    # Not packaged (e.g. apt). Try fastest options first:
    #   1) official prebuilt GitHub binary (no build)
    #   2) cargo binstall (prebuilt via cargo)
    #   3) build from source via the 'yazi-build' meta-crate (Cargo limitation)
    info "yazi not available via $PM — trying prebuilt binary..."
    if install_yazi_from_github; then
        unmark_manual yazi; return 0
    fi

    if command -v cargo-binstall >/dev/null 2>&1 || \
       { ensure_cargo && cargo install cargo-binstall >/dev/null 2>&1; }; then
        info "Installing yazi via cargo binstall..."
        if cargo binstall -y yazi-fm yazi-cli; then
            unmark_manual yazi; return 0
        fi
    fi

    info "Falling back to building yazi from source..."
    if ensure_build_tools && ensure_cargo && cargo install --force yazi-build; then
        unmark_manual yazi; return 0
    fi

    warn "Could not install yazi automatically."
}

#--------------------------------------------------------------------
# Per-package extra dependencies (installed only when selected)
#--------------------------------------------------------------------
pkg_deps() {
    case "$1" in
        hypr)      echo "hyprland hypridle hyprlock hyprsunset" ;;
        waybar)    echo "waybar" ;;
        dunst)     echo "dunst" ;;
        tofi)      echo "tofi" ;;
        wal)       echo "pywal" ;;
        foot)      echo "foot" ;;
        MangoHud)  echo "mangohud" ;;
        rmpc)      echo "rmpc" ;;
        aerospace) echo "aerospace" ;;
        ghostty)   echo "ghostty" ;;
        *)         echo "" ;;
    esac
}

install_selected_deps() {
    local pkg deps
    local to_install=()
    for pkg in "${SELECTED[@]}"; do
        deps="$(pkg_deps "$pkg")"
        [[ -n "$deps" ]] && to_install+=($deps)
    done
    if [[ ${#to_install[@]} -gt 0 ]]; then
        step "Installing dependencies for selected packages"
        pkg_install "${to_install[@]}"
    fi

    # Tools with special install/fallback handling, only if selected.
    if selected_has starship; then step "Installing starship"; install_starship; fi
    if selected_has yazi;     then step "Installing yazi";     install_yazi;     fi
    if selected_has opencode; then step "Installing opencode"; install_opencode; fi
}

# True if a package is in the SELECTED list.
selected_has() {
    local p
    for p in "${SELECTED[@]}"; do [[ "$p" == "$1" ]] && return 0; done
    return 1
}

#--------------------------------------------------------------------
# Neovim: compare packaged version with GitHub stable
#--------------------------------------------------------------------
ver_normalize() { sed -E 's/^v//; s/[^0-9.].*$//'; }
ver_ge() {
    # ver_ge A B -> 0 if A >= B
    [ "$(printf '%s\n%s\n' "$1" "$2" | sort -V | head -n1)" = "$2" ]
}

pm_nvim_version() {
    case "$PM" in
        brew)   brew info --json=v2 neovim 2>/dev/null | grep -m1 '"stable"' | sed -E 's/.*"stable": *"([^"]+)".*/\1/' ;;
        apt)    apt-cache policy neovim 2>/dev/null | awk '/Candidate:/{print $2}' ;;
        pacman) pacman -Si neovim 2>/dev/null | awk -F': ' '/Version/{print $2; exit}' ;;
        dnf)    dnf info neovim 2>/dev/null | awk -F': ' '/Version/{print $2; exit}' ;;
    esac
}

install_neovim() {
    step "Neovim"
    local gh_ver pm_ver
    # The 'stable' tag is a moving alias (tag_name == "stable"); use the
    # latest release, whose tag_name is the real version (e.g. v0.12.4).
    # The trailing '|| true' stops a failed pipe (e.g. no network, grep no
    # match) from aborting the script under 'set -e -o pipefail'.
    gh_ver="$(curl -s https://api.github.com/repos/neovim/neovim/releases/latest 2>/dev/null \
        | grep -m1 '"tag_name"' | sed -E 's/.*"tag_name": *"([^"]+)".*/\1/' | ver_normalize || true)"
    pm_ver="$(pm_nvim_version | ver_normalize || true)"

    if [[ -z "$gh_ver" ]]; then
        warn "Couldn't reach GitHub for the latest stable version; using the packaged neovim."
        pkg_install neovim; return
    fi
    if [[ -z "$pm_ver" ]]; then
        warn "Neovim not offered by $PM. Latest stable is v$gh_ver."
        info "See https://github.com/neovim/neovim/releases/tag/stable for a prebuilt binary."
        MANUAL_DEPS+=("neovim (v$gh_ver)")
        return
    fi

    info "Packaged neovim: v$pm_ver  |  GitHub stable: v$gh_ver"
    if ver_ge "$pm_ver" "$gh_ver"; then
        info "Packaged version is up to date — installing via $PM."
        pkg_install neovim
    else
        warn "Packaged neovim (v$pm_ver) is older than stable (v$gh_ver)."
        if confirm "Install the older packaged version anyway?"; then
            pkg_install neovim
        else
            info "Skipping. Grab the prebuilt stable binary from:"
            info "  https://github.com/neovim/neovim/releases/tag/stable"
            MANUAL_DEPS+=("neovim (v$gh_ver)")
        fi
    fi
}

#--------------------------------------------------------------------
# Package discovery & selection
#--------------------------------------------------------------------
ALL_PACKAGES=()
discover_packages() {
    local d base
    for d in "$REPO_DIR"/*/; do
        base="$(basename "$d")"
        local skip=0
        local np
        for np in "${NON_PACKAGES[@]}"; do [[ "$base" == "$np" ]] && skip=1; done
        [[ $skip -eq 0 ]] && ALL_PACKAGES+=("$base")
    done
}

# Predefined groups
GROUP_CORE=(zsh shell nvim starship tmux bin ssh xdg-dirs yazi)
GROUP_DESKTOP_LINUX=(hypr waybar dunst tofi wal foot MangoHud)
GROUP_DESKTOP_MACOS=(aerospace ghostty)

expand_group() {
    case "$1" in
        core)          printf '%s\n' "${GROUP_CORE[@]}" ;;
        desktop-linux) printf '%s\n' "${GROUP_DESKTOP_LINUX[@]}" ;;
        desktop-macos) printf '%s\n' "${GROUP_DESKTOP_MACOS[@]}" ;;
        all)           printf '%s\n' "${ALL_PACKAGES[@]}" ;;
    esac
}

# Comma-separated contents of a group (for display).
group_contents() {
    expand_group "$1" | awk 'NR>1{printf ", "}{printf "%s",$0}END{print ""}'
}

# Print what each offered group contains.
print_group_legend() {
    info "Group contents:"
    printf "    %-16s %s\n" "all" "every package"
    printf "    %-16s %s\n" "core" "$(group_contents core)"
    [[ "$OS" == "linux" ]] && printf "    %-16s %s\n" "desktop-linux" "$(group_contents desktop-linux)"
    [[ "$OS" == "macos" ]] && printf "    %-16s %s\n" "desktop-macos" "$(group_contents desktop-macos)"
    return 0
}

# Choose a multi-select tool. Prefer gum, then fzf, else bash select.
# Sets the global SELECTOR (not echoed) so interactive prompts work — a
# command-substitution subshell would swallow the confirm prompt.
SELECTOR=""
pick_selector() {
    if command -v gum >/dev/null 2>&1; then SELECTOR="gum"; return; fi
    if command -v fzf >/dev/null 2>&1; then SELECTOR="fzf"; return; fi
    # Offer to install gum (except Debian/apt, where we fall back to fzf/select).
    if [[ "$PM" != "apt" ]] && confirm "Install 'gum' for a nicer selection menu?"; then
        pkg_install gum
        command -v gum >/dev/null 2>&1 && { SELECTOR="gum"; return; }
    fi
    command -v fzf >/dev/null 2>&1 && { SELECTOR="fzf"; return; }
    SELECTOR="select"
}

SELECTED=()
select_packages() {
    step "Choose what to install"
    print_group_legend

    # Build the menu: groups first (with their contents shown), then packages.
    # Group entries are labelled "group:<name>  (pkg, pkg, ...)"; the leading
    # "group:<name>" token is parsed back out when expanding.
    local menu=()
    menu+=("group:all  (everything)")
    menu+=("group:core  ($(group_contents core))")
    [[ "$OS" == "linux" ]] && menu+=("group:desktop-linux  ($(group_contents desktop-linux))")
    [[ "$OS" == "macos" ]] && menu+=("group:desktop-macos  ($(group_contents desktop-macos))")
    local p
    for p in "${ALL_PACKAGES[@]}"; do menu+=("$p"); done

    local suggested="core"
    [[ "$OS" == "macos" ]] && suggested="core + desktop-macos"
    [[ "$OS" == "linux" ]] && suggested="core + desktop-linux"
    info "Suggested for $OS: $suggested (you can pick anything below)"

    local chosen=() line
    pick_selector

    # NOTE: use a `while read` loop rather than `mapfile`/`readarray`, which
    # don't exist in bash 3.2 (the default on macOS).
    case "$SELECTOR" in
        gum)
            while IFS= read -r line; do [[ -n "$line" ]] && chosen+=("$line"); done \
                < <(printf '%s\n' "${menu[@]}" | \
                    gum choose --no-limit --header="Space to select, Enter to confirm" || true) ;;
        fzf)
            while IFS= read -r line; do [[ -n "$line" ]] && chosen+=("$line"); done \
                < <(printf '%s\n' "${menu[@]}" | \
                    fzf --multi --prompt="select> " \
                        --header="TAB to select multiple, Enter to confirm" || true) ;;
        select)
            echo "Enter numbers separated by spaces (e.g. '1 3 5'):"
            local i=1
            for item in "${menu[@]}"; do printf "  %2d) %s\n" "$i" "$item"; i=$((i+1)); done
            local nums reply
            read -r reply
            for nums in $reply; do
                [[ "$nums" =~ ^[0-9]+$ ]] && chosen+=("${menu[$((nums-1))]}")
            done ;;
    esac

    [[ ${#chosen[@]} -eq 0 ]] && { error "Nothing selected. Aborting."; exit 1; }

    # Expand groups and de-duplicate. A group label looks like
    # "group:core  (zsh, shell, ...)"; take the first whitespace-delimited
    # field ("group:core") and strip the "group:" prefix.
    local raw=() c token
    for c in "${chosen[@]}"; do
        if [[ "$c" == group:* ]]; then
            token="${c%% *}"          # -> group:core
            while read -r g; do raw+=("$g"); done < <(expand_group "${token#group:}")
        else
            raw+=("$c")
        fi
    done
    # de-dup
    local seen=" " item
    for item in "${raw[@]}"; do
        [[ "$seen" == *" $item "* ]] && continue
        SELECTED+=("$item"); seen+="$item "
    done

    info "Will stow: ${SELECTED[*]}"
}

#--------------------------------------------------------------------
# Stow
#--------------------------------------------------------------------
# Back up any existing non-symlink targets that would block stowing $pkg,
# so a fresh machine with default dotfiles (e.g. ~/.zshenv) doesn't conflict.
# Backups go to <file>.pre-stow.bak.
backup_conflicts() {
    local pkg="$1" rel target
    # List files the package provides (relative to the package dir).
    while IFS= read -r rel; do
        target="$HOME/$rel"
        # Only back up real files/dirs that aren't already our symlink.
        if [[ -e "$target" && ! -L "$target" ]]; then
            info "Backing up existing $target -> $target.pre-stow.bak"
            mv "$target" "$target.pre-stow.bak"
        fi
    done < <(cd "$REPO_DIR/$pkg" && find . -type f -o -type l | sed 's|^\./||')
}

stow_packages() {
    step "Stowing packages"
    local pkg
    for pkg in "${SELECTED[@]}"; do
        if [[ ! -d "$REPO_DIR/$pkg" ]]; then
            warn "Package '$pkg' not found in $REPO_DIR — skipping."
            continue
        fi
        info "stow -R $pkg"
        if ! ( cd "$REPO_DIR" && stow -R "$pkg" ) 2>/dev/null; then
            # Likely a conflict with pre-existing files — back them up and retry.
            warn "Conflicts detected for '$pkg'; backing up existing files and retrying."
            backup_conflicts "$pkg"
            if ! ( cd "$REPO_DIR" && stow -R "$pkg" ); then
                warn "Failed to stow '$pkg' — resolve manually."
            fi
        fi
    done
}

#--------------------------------------------------------------------
# Shell change (guarded)
#--------------------------------------------------------------------
set_default_shell() {
    step "Default shell"
    local zsh_path
    zsh_path="$(command -v zsh || true)"
    [[ -z "$zsh_path" ]] && { warn "zsh not found on PATH; skipping shell change."; return; }

    if [[ "${SHELL:-}" == "$zsh_path" ]]; then
        info "zsh is already your login shell."
        return
    fi
    if ! confirm "Set zsh ($zsh_path) as your default shell?"; then
        info "Leaving login shell unchanged."
        return
    fi
    # Ensure the zsh path is a valid login shell (needed for Homebrew zsh).
    if ! grep -qx "$zsh_path" /etc/shells 2>/dev/null; then
        info "Adding $zsh_path to /etc/shells"
        echo "$zsh_path" | sudo tee -a /etc/shells >/dev/null
    fi
    if chsh -s "$zsh_path"; then
        info "Login shell set to zsh (restart your terminal)."
    else
        warn "chsh failed; set your shell manually: chsh -s $zsh_path"
    fi
}

#--------------------------------------------------------------------
# Main
#--------------------------------------------------------------------
main() {
    print_banner
    printf "\n${GREEN}Dotfiles installer${NC}\n"
    printf "Repo: %s\n" "$REPO_DIR"
    printf "You'll pick which configs to install, then this will install their\n"
    printf "dependencies, stow them, and optionally set zsh as your shell.\n\n"

    detect_platform
    confirm "Continue?" || { info "Aborted."; exit 0; }

    ensure_homebrew
    discover_packages

    # Choose everything first (the only thing that may install beforehand is
    # gum, if you opt in for a nicer menu), then do all installs together.
    select_packages

    install_core_deps
    install_selected_deps
    install_neovim
    stow_packages
    set_default_shell

    step "Done"
    info "Stowed: ${SELECTED[*]}"
    # Filter out any empty entries before reporting.
    local real_manual=() d
    for d in "${MANUAL_DEPS[@]:-}"; do [[ -n "$d" ]] && real_manual+=("$d"); done
    if [[ ${#real_manual[@]} -gt 0 ]]; then
        warn "These need manual installation: ${real_manual[*]}"
    fi
    info "Open a new terminal to pick up your new shell/config."
}

main "$@"
