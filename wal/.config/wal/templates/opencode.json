{
  "$schema": "https://opencode.ai/theme.json",
  "theme": {
    "primary": { "dark": "{color4}", "light": "{color4}" },
    "secondary": { "dark": "{color6}", "light": "{color6}" },
    "accent": { "dark": "{color5}", "light": "{color5}" },
    "error": { "dark": "{color1}", "light": "{color1}" },
    "warning": { "dark": "{color3}", "light": "{color3}" },
    "success": { "dark": "{color2}", "light": "{color2}" },
    "info": { "dark": "{color4}", "light": "{color4}" },
    "text": { "dark": "{foreground}", "light": "{color0}" },
    "textMuted": { "dark": "{color8}", "light": "{color8}" },
    "background": { "dark": "{background}", "light": "{color7}" },
    "backgroundPanel": { "dark": "{color0}", "light": "{color7}" },
    "backgroundElement": { "dark": "{color0}", "light": "{color8}" },
    "border": { "dark": "{color8}", "light": "{color8}" },
    "borderActive": { "dark": "{color4}", "light": "{color4}" },
    "borderSubtle": { "dark": "{color0}", "light": "{color0}" },
    "diffAdded": { "dark": "{color2}", "light": "{color2}" },
    "diffRemoved": { "dark": "{color1}", "light": "{color1}" },
    "diffContext": { "dark": "{color8}", "light": "{color8}" },
    "diffHunkHeader": { "dark": "{color6}", "light": "{color6}" },
    "diffHighlightAdded": { "dark": "{color2}", "light": "{color2}" },
    "diffHighlightRemoved": { "dark": "{color1}", "light": "{color1}" },
    "diffAddedBg": { "dark": "{color2}", "light": "{color2}" },
    "diffRemovedBg": { "dark": "{color1}", "light": "{color1}" },
    "diffContextBg": { "dark": "{color0}", "light": "{color0}" },
    "diffLineNumber": { "dark": "{color8}", "light": "{color8}" },
    "diffAddedLineNumberBg": { "dark": "{color0}", "light": "{color0}" },
    "diffRemovedLineNumberBg": { "dark": "{color0}", "light": "{color0}" },
    "markdownText": { "dark": "{foreground}", "light": "{color0}" },
    "markdownHeading": { "dark": "{color4}", "light": "{color4}" },
    "markdownLink": { "dark": "{color6}", "light": "{color6}" },
    "markdownLinkText": { "dark": "{color5}", "light": "{color5}" },
    "markdownCode": { "dark": "{color2}", "light": "{color2}" },
    "markdownBlockQuote": { "dark": "{color8}", "light": "{color8}" },
    "markdownEmph": { "dark": "{color3}", "light": "{color3}" },
    "markdownStrong": { "dark": "{color5}", "light": "{color5}" },
    "markdownHorizontalRule": { "dark": "{color8}", "light": "{color8}" },
    "markdownListItem": { "dark": "{color4}", "light": "{color4}" },
    "markdownListEnumeration": { "dark": "{color5}", "light": "{color5}" },
    "markdownImage": { "dark": "{color6}", "light": "{color6}" },
    "markdownImageText": { "dark": "{color5}", "light": "{color5}" },
    "markdownCodeBlock": { "dark": "{foreground}", "light": "{color0}" },
    "syntaxComment": { "dark": "{color8}", "light": "{color8}" },
    "syntaxKeyword": { "dark": "{color6}", "light": "{color6}" },
    "syntaxFunction": { "dark": "{color4}", "light": "{color4}" },
    "syntaxVariable": { "dark": "{color5}", "light": "{color5}" },
    "syntaxString": { "dark": "{color2}", "light": "{color2}" },
    "syntaxNumber": { "dark": "{color5}", "light": "{color5}" },
    "syntaxType": { "dark": "{color5}", "light": "{color5}" },
    "syntaxOperator": { "dark": "{color6}", "light": "{color6}" },
    "syntaxPunctuation": { "dark": "{foreground}", "light": "{color0}" }
  }
}
