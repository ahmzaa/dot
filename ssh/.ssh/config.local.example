# Machine-specific SSH config — copy to ~/.ssh/config.local and edit.
# This file is NOT tracked by the dotfiles repo (see .gitignore).
#
# CA host used by `ssh-cert` for certificate renewal. Using ControlMaster
# means the scp/ssh/scp renewal steps share a single authenticated
# connection. Auth is key-based (the bootstrap key), so no password prompt.

# Host ca
#     HostName <ca-host-or-ip>
#     User <your-login>
#     IdentityFile ~/.ssh/id_ed25519
#     ControlMaster auto
#     ControlPath ~/.ssh/cm-%r@%h:%p
#     ControlPersist 10m
