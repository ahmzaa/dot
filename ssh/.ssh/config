# Managed by dotfiles (stow package: ssh)
#
# Machine-specific / sensitive host blocks live in ~/.ssh/config.local
# (not tracked by this repo). See docs/ssh-cert-setup.md.
Include ~/.ssh/config.local

Host *
    AddKeysToAgent yes
    IdentityFile ~/.ssh/id_ed25519

# macOS only: load/store key passphrases in the Keychain. The `Match exec`
# guard keeps Linux OpenSSH (which does not know `UseKeychain`) from erroring.
Match exec "uname -s | grep -q Darwin"
    UseKeychain yes
